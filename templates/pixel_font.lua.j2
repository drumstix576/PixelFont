--- PixelFont — pixel-exact tracker font + FRLG-style icon drop shadows.
---
--- Replaces TrackerPixelFont and ShadowedIcons. Generated by
--- generate_pixel_font.py from font_groups/*.png and icons.png.
---
--- Text glyphs: 0 = transparent, 1 = foreground, 2 = shadow. The shadow
--- color is computed at render time as half-brightness of the FG color,
--- so shadows follow whatever text color the caller specified.
---
--- Icon glyphs: 0 = transparent, 1..N = source color values (preserved
--- from Constants.PixelImages), N+1 = shadow. The Drawing.drawImageAsPixels
--- wrapper extends the colorList with shadowColor(colorList[1]) at index
--- N+1 so the base renderer paints those pixels.
---
--- Icon shadows are gated by the RogueMon Options toggle "Pixel-art icon
--- shadows" (default on). Text font is always active when this extension
--- is enabled.

local function PixelFont()
  local self = {}
  self.version = "2.0"
  self.name = "PixelFont"
  self.author = "Generated"
  self.description = "Pixel-exact tracker font and FRLG-style icon drop shadows."

  -- pristineOriginal: cache the first-seen value of a key so wrapper chains
  -- don't form across reloads. Prefers Roguemon.pristineOriginal (same
  -- _G.__roguemonCoreOriginals cache) for cross-extension consistency;
  -- falls back to direct cache when RogueMon isn't loaded.
  local function pristine(key, current)
    if _G.Roguemon and _G.Roguemon.pristineOriginal then
      return _G.Roguemon.pristineOriginal(key, current)
    end
    _G.__roguemonCoreOriginals = _G.__roguemonCoreOriginals or {}
    if _G.__roguemonCoreOriginals[key] == nil then
      _G.__roguemonCoreOriginals[key] = current
    end
    return _G.__roguemonCoreOriginals[key]
  end

  -- Shadow opacity. Effective formula is opaque per-channel:
  --   shadow = SHADOW_ALPHA * FG + (1 - SHADOW_ALPHA) * BG
  -- 0.5 ≈ 50% alpha (the visual default); raise toward 1.0 for a darker
  -- / stronger shadow, lower toward 0.0 to fade it into the BG. Stays
  -- opaque so two writes to the same pixel don't accumulate brighter.
  -- Edit this value to tune; no regen needed.
  local SHADOW_ALPHA = 0.25

  -- Header strip BG override. The move-table header (Moves N/M (LVL),
  -- PP, Pow, Acc) is drawn with bgHeaderShadow derived from
  -- Theme.COLORS["Main background"], but the visible strip can be a
  -- different color (custom theme paint, bleed-through from the game
  -- viewport, BizHawk's default GUI surface). If the visible BG doesn't
  -- match Main background, set this to the actual BG color (ARGB hex,
  -- 0xFFRRGGBB) so PixelFont mixes the shadow against the right BG and
  -- avoids a black halo over a tinted strip. nil = use Main background.
  local HEADER_BG = nil

  -- Per-channel weighted blend of FG and BG. bgColor=nil treats BG as
  -- black, the right answer over a dark panel and the legacy behavior.
  -- Passing the actual BG matters on tinted panels (e.g. the purple
  -- curses backdrop, the green FC-prize carousel) where a BG-less
  -- darkening reads as a near-black halo instead of a tonally
  -- consistent shadow.
  local function shadowColor(color, bgColor)
    local rgb = color % 0x01000000
    local r = math.floor(rgb / 0x10000)
    local g = math.floor((rgb % 0x10000) / 0x100)
    local b = rgb % 0x100
    local br, bg, bb = 0, 0, 0
    if bgColor then
      local brgb = bgColor % 0x01000000
      br = math.floor(brgb / 0x10000)
      bg = math.floor((brgb % 0x10000) / 0x100)
      bb = brgb % 0x100
    end
    local a = SHADOW_ALPHA
    local ia = 1 - a
    return 0xFF000000 + math.floor(r * a + br * ia + 0.5) * 0x10000
                      + math.floor(g * a + bg * ia + 0.5) * 0x100
                      + math.floor(b * a + bb * ia + 0.5)
  end

  -- Recover the caller's BG from the shadowcolor arg. The tracker derives
  -- shadowcolor as Utils.calcShadowColor(bg) = bg * 0.92, so dividing by
  -- 0.92 reverses the scale within rounding. Returns nil when no usable
  -- shadowcolor is supplied so shadowColor() falls back to FG/2.
  local function bgFromShadowColor(sc)
    if type(sc) ~= "number" then return nil end
    local rgb = sc % 0x01000000
    local r = math.floor(rgb / 0x10000)
    local g = math.floor((rgb % 0x10000) / 0x100)
    local b = rgb % 0x100
    local function unscale(v)
      local u = math.floor(v / 0.92 + 0.5)
      if u > 255 then u = 255 end
      return u
    end
    return 0xFF000000 + unscale(r) * 0x10000 + unscale(g) * 0x100 + unscale(b)
  end

  -- Build a shadowed copy of an icon table. Preserves non-numeric metadata
  -- (iconColors, getColors), extends both with shadow color at the shadow
  -- index, and replaces matrix rows. Tags so the drawImageAsPixels wrapper
  -- recognizes shadowed matrices.
  local function makeShadowed(orig, newRows, shadowValue)
    local out = {}
    if type(orig) == "table" then
      for k, v in pairs(orig) do
        if type(k) ~= "number" then out[k] = v end
      end
      if out.iconColors then
        local extended = {}
        for i, c in ipairs(out.iconColors) do extended[i] = c end
        extended[shadowValue] = shadowColor(out.iconColors[1])
        out.iconColors = extended
      end
      local origGetColors = out.getColors
      if type(origGetColors) == "function" then
        out.getColors = function(t)
          local list = origGetColors(t)
          local extended = {}
          for i, c in ipairs(list) do extended[i] = c end
          extended[shadowValue] = shadowColor(list[1])
          return extended
        end
      end
    end
    for i, row in ipairs(newRows) do out[i] = row end
    out._shadowed = true
    out._shadowValue = shadowValue
    return out
  end

  -- Read the RogueMon Options toggle (default on if RogueMon not loaded).
  local function iconShadowsEnabled()
    if _G.Roguemon and _G.Roguemon.OptionsManager
        and _G.Roguemon.OptionsManager.isEnabled then
      return _G.Roguemon.OptionsManager.isEnabled("Pixel-art icon shadows") ~= false
    end
    return true
  end

  -- Vertical leading: uniform across the font. BizHawk renders Franklin
  -- Gothic 9pt with baseline at y+9 (for drawText at y), and our padded
  -- matrices put the baseline at matrix row (FONT_ASCENT). We shift by
  -- (9 - FONT_ASCENT) so the two baselines coincide.
  local Y_LEADING = {{ Y_LEADING }}

  -- Inline-newline line gap. The native gui.drawText renders multi-line
  -- text using Franklin Gothic's natural line height (~9-10 px), tighter
  -- than the tracker's logical LINE_SPACING (11) used for stacking
  -- separate calls. Matching ~10 here keeps inline-wrapped text from
  -- overflowing the boxes the tracker sized for native font metrics
  -- (e.g. SegmentUI's wrapped carousel: line 1 at y=136, expects line 2
  -- to land at y=146 inside a box bordered at y=155).
  local NEWLINE_SPACING = {{ LINE_SPACING }} - 1

  -- Carousel "second-line" y-coercion. Vanilla TrackerScreen and
  -- SegmentUI both draw second-line carousel content at y=145 (computed
  -- as MARGIN+140 in SegmentUI's count text or as a literal in vanilla
  -- TrackerScreen.drawCarouselArea). With our taller font_height=11,
  -- those land 1 px above the FRLG-correct visual baseline; bump to 146
  -- so they vertically align with the wrapped second line at y+10.
  function self.drawText(x, y, text, color, shadowcolor, size, family, style)
    if Utils.isNilOrEmpty(text) then return end
    -- Fall back to the original renderer for anything that isn't the
    -- default body font (icons at size 5, headers at 15, etc.).
    if size ~= nil and size ~= {{ FONT_SIZE }} then
      return self.oldDrawText(x, y, text, color, shadowcolor, size, family, style)
    end
    if y == 145 then y = 146 end
    -- shadowcolor=false → caller explicitly opted out of the drop shadow
    -- (e.g. text drawn over the game viewport where a half-brightness
    -- echo of the FG reads as solid black against bright backgrounds).
    -- shadowcolor=number → tracker's calcShadowColor(BG); recover BG and
    -- mix with FG so the shadow tones match the panel (e.g. purple curses
    -- backdrop) rather than always darkening toward black.
    -- shadowcolor=nil → no BG hint; FG/2 (assumes black BG).
    local colorList
    if shadowcolor == false then
      colorList = { color }
    else
      colorList = { color, shadowColor(color, bgFromShadowColor(shadowcolor)) }
    end
    local xoffset = 0
    local yoffset = 0
    for c in tostring(text):gmatch(utf8.charpattern) do
      if c == "\n" then
        yoffset = yoffset + 1
        xoffset = 0
      else
        local glyph = self.Font[c]
        if glyph then
          -- Per-char left bearing matches the native font's metric, so
          -- the pixel glyph lands at the same x as gui.drawText would.
          local lb = self.FontLeftBearing[c] or 1
          Drawing.drawImageAsPixels(glyph,
            x + xoffset + lb,
            y + yoffset * NEWLINE_SPACING + Y_LEADING,
            colorList, nil)
        end
        -- Advance by the glyph's foreground width plus 1 px so the next
        -- glyph's leftmost FG sits one column past this glyph's rightmost
        -- FG. That one-column gap is where the right-edge shadow lives.
        xoffset = xoffset + (self.FontWidths[c] or {{ DEFAULT_WIDTH }}) + 1
      end
    end
  end


  -- Glyph matrices: 0=transparent, 1=foreground, 2=shadow.
  -- All glyphs padded to {{ FONT_HEIGHT }} rows with baselines aligned.
  self.Font = {
{{ font_table }}
  }

  self.FontWidths = {
    [" "] = {{ SPACE_WIDTH }},
{{ font_widths_table }}
  }

  -- Per-char left bearing = offset from the caller's x
  -- to the glyph's leftmost FG column, taken from the atlas.
  self.FontLeftBearing = {
{{ font_left_bearing_table }}
  }
{% if icon_tables %}
{{ icon_tables }}
{% endif %}

  -- Wrap Drawing.drawImageAsPixels so shadowed icon matrices get a shadow
  -- color injected into colorList at index = matrix._shadowValue. Pass
  -- shadowcolor=nil through so the base function's +1,+1 echo doesn't
  -- double up on our explicit shadow pixels. Non-shadowed matrices pass
  -- through unchanged.
  local _baseDrawImageAsPixels
  local _wrapInstalled = false

  local function shadowDrawImageAsPixels(matrix, x, y, color, sc)
    if matrix == nil or not matrix._shadowed then
      -- Non-shadowed icon: apply the same FG/BG midpoint formula text
      -- uses, so icons drawn over tinted panels (green FC-prize panel,
      -- purple curse panel) get a tonally consistent shadow instead of
      -- the darker calcShadowColor(BG) tint the caller passed in.
      if type(sc) == "number" then
        local fg
        if type(color) == "number" then
          fg = color
        elseif type(color) == "table" then
          fg = color[1]
        elseif matrix.iconColors then
          fg = matrix.iconColors[1]
        elseif type(matrix.getColors) == "function" then
          local list = matrix:getColors()
          fg = list and list[1]
        end
        if fg then
          sc = shadowColor(fg, bgFromShadowColor(sc))
        end
      end
      return _baseDrawImageAsPixels(matrix, x, y, color, sc)
    end
    local sv = matrix._shadowValue
    local colorList
    if not color then
      if type(matrix.getColors) == "function" then
        colorList = matrix:getColors()
      elseif matrix.iconColors then
        colorList = matrix.iconColors
      end
      colorList = colorList or { Theme.COLORS["Default text"] }
    elseif type(color) == "number" then
      colorList = { color }
    else
      colorList = color
    end
    if sc == false then
      -- Caller opted out of the drop shadow. Strip the shadow entry so the
      -- base renderer skips matrix pixels with value sv (nil colorList[sv]
      -- causes the per-pixel branch in Drawing.drawImageAsPixels to no-op).
      if colorList[sv] ~= nil then
        local truncated = {}
        for i = 1, sv - 1 do truncated[i] = colorList[i] end
        colorList = truncated
      end
    else
      -- Always recompute the shadow at draw time so we can honor the BG
      -- hint encoded in `sc` (the same calcShadowColor(BG) value the
      -- caller would pass to Drawing.drawText). Mixing FG with BG keeps
      -- icon shadows tonally consistent on tinted panels instead of
      -- collapsing to a near-black halo.
      local bg = bgFromShadowColor(sc)
      local extended = {}
      for i = 1, math.max(sv, #colorList) do extended[i] = colorList[i] end
      extended[sv] = shadowColor(colorList[1], bg)
      colorList = extended
    end
    return _baseDrawImageAsPixels(matrix, x, y, colorList, nil)
  end

  function self.startup()
    -- Publish ourselves so other extensions can detect "PixelFont is
    -- loaded" and use the `false`-shadowcolor opt-out sentinel safely:
    --   Drawing.drawText(x, y, t, color, _G.PixelFont and false)
    -- evaluates to `false` when we're loaded (PixelFont's wrappers honor
    -- it) and `nil` when we aren't (native treats nil as no-shadow).
    _G.PixelFont = self

    -- Text override (immediate; no conflict with other extensions).
    self.oldDrawText = Drawing.drawText
    Drawing.drawText = self.drawText
    -- Patch Constants.Char widths so Utils.calcWordPixelLength matches
    -- what we actually render (avoids misaligned overdraws like the
    -- yellow evo-level highlight).
    self._savedCharWidths = {}
    for c, w in pairs(self.FontWidths) do
      if Constants.Char[c] then
        self._savedCharWidths[c] = Constants.Char[c].width
        Constants.Char[c].width = w
      end
    end
    -- drawMovesArea wrap. Used for two distinct fixes:
    --   1. Move-name spacing: when icon shadows widen PHYSICAL/SPECIAL by
    --      a column, shift the move name's drawText by +1 so it doesn't
    --      butt up against the icon's shadow.
    --   2. Header strip BG override: when HEADER_BG is set, replace the
    --      shadowcolor on drawText calls at headerY (y=81) with one
    --      derived from the actual visible BG, so PixelFont's midpoint
    --      formula tints toward that color instead of the theme's
    --      "Main background" assumption.
    if TrackerScreen and TrackerScreen.drawMovesArea then
      self._oldDrawMovesArea = TrackerScreen.drawMovesArea
      TrackerScreen.drawMovesArea = function(...)
        local shiftIcons = iconShadowsEnabled() and Options and Options["Show physical special icons"]
        local headerBgShadow = HEADER_BG and Utils and Utils.calcShadowColor and Utils.calcShadowColor(HEADER_BG) or nil
        if not shiftIcons and not headerBgShadow then
          return self._oldDrawMovesArea(...)
        end
        local targetX
        if shiftIcons then
          local moveNameOffset = 6 + 8
          if Theme and not Theme.MOVE_TYPES_ENABLED then
            moveNameOffset = moveNameOffset + 5
          end
          targetX = Constants.SCREEN.WIDTH + moveNameOffset
        end
        local origDrawText = Drawing.drawText
        Drawing.drawText = function(x, y, text, color, shadowcolor, ...)
          if targetX and x == targetX then x = x + 1 end
          if headerBgShadow and y == 81 then shadowcolor = headerBgShadow end
          return origDrawText(x, y, text, color, shadowcolor, ...)
        end
        local ok, err = pcall(self._oldDrawMovesArea, ...)
        Drawing.drawText = origDrawText
        if not ok then error(err) end
      end
    end
    -- nextMoveSpacing fix: Utils.getMovesLearnedHeader returns the
    -- spacing of the highlighted level overdraw as
    -- `calcWordPixelLength(prefix)` (Utils.lua:622). Two issues for our
    -- pixel font:
    --   1. Other callsites use `1 + calcWordPixelLength(...)` (compare
    --      TrackerScreen.lua:1191); this one's missing the +1.
    --   2. calcWordPixelLength reads Constants.Char widths, which we
    --      patch to match FontWidths in startup — but that patch can
    --      drift across reloads or be reset by other extensions, leaving
    --      the +1 fix over- or under-shifted by one column for chars
    --      whose widths differ (e.g. "/" is native=4, ours=3).
    -- Recompute directly from FontWidths so the overdraw position is
    -- always exactly where our renderer places the white prefix's last
    -- char, independent of Constants.Char state.
    if Utils and Utils.getMovesLearnedHeader then
      self._oldGetMovesLearnedHeader = Utils.getMovesLearnedHeader
      Utils.getMovesLearnedHeader = function(...)
        local header, lvl, sp = self._oldGetMovesLearnedHeader(...)
        if sp and header then
          local prefix = header:match("^(.-%()")
          if prefix then
            local total = 0
            for c in tostring(prefix):gmatch(utf8.charpattern) do
              total = total + (self.FontWidths[c] or 1) + 1
            end
            sp = total
          end
        end
        return header, lvl, sp
      end
    end
    -- Icon overrides: mutate Constants.PixelImages with shadowed copies.
    -- Gated by Options toggle so users can disable without restart.
    if iconShadowsEnabled() then
      for name, entry in pairs(self.ShadowedIcons) do
        local origEntry = pristine("Constants.PixelImages." .. name,
                                   Constants.PixelImages[name])
        if origEntry then
          Constants.PixelImages[name] = makeShadowed(
            origEntry, entry.matrix, entry.shadow_value)
        end
      end
      -- RogueMon-extension-local matrices: expose via shared registry so
      -- consuming files can opt in (e.g. POKEDOLLAR_GLYPH).
      if _G.Roguemon then
        _G.Roguemon.ShadowedIcons = _G.Roguemon.ShadowedIcons or {}
        for name, entry in pairs(self.ExternalShadowedIcons) do
          _G.Roguemon.ShadowedIcons[name] = makeShadowed(
            {}, entry.matrix, entry.shadow_value)
        end
      end
    end
  end

  function self.afterRedraw()
    -- Defer Drawing.drawImageAsPixels wrap to first frame, AFTER all other
    -- extensions have completed startup. Lua's pairs() iteration over
    -- CustomCode.ExtensionLibrary is non-deterministic, so we can't predict
    -- whether RoguemonExpansion's RLE override (which directly assigns
    -- Drawing.drawImageAsPixels in startup()) runs before or after us. Wrap
    -- here and we always sit on top of whatever the final version is.
    if not _wrapInstalled and iconShadowsEnabled() then
      _baseDrawImageAsPixels = pristine("Drawing.drawImageAsPixels",
                                        Drawing.drawImageAsPixels)
      Drawing.drawImageAsPixels = shadowDrawImageAsPixels
      _wrapInstalled = true
    end
  end

  function self.unload()
    if _G.PixelFont == self then _G.PixelFont = nil end
    Drawing.drawText = self.oldDrawText
    if self._savedCharWidths then
      for c, w in pairs(self._savedCharWidths) do
        if Constants.Char[c] then Constants.Char[c].width = w end
      end
      self._savedCharWidths = nil
    end
    if self._oldGetMovesLearnedHeader and Utils then
      Utils.getMovesLearnedHeader = self._oldGetMovesLearnedHeader
      self._oldGetMovesLearnedHeader = nil
    end
    if self._oldDrawMovesArea and TrackerScreen then
      TrackerScreen.drawMovesArea = self._oldDrawMovesArea
      self._oldDrawMovesArea = nil
    end
    if _baseDrawImageAsPixels then
      Drawing.drawImageAsPixels = _baseDrawImageAsPixels
    end
    local cache = _G.__roguemonCoreOriginals
    if cache then
      for name in pairs(self.ShadowedIcons) do
        local orig = cache["Constants.PixelImages." .. name]
        if orig then Constants.PixelImages[name] = orig end
      end
    end
  end

  return self
end

return PixelFont
